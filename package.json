{
  "name": "uaip",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Edge-native LLM gateway + personal portal on Cloudflare Pages (zero framework, zero runtime deps, D1 only).",
  "scripts": {
    "dev": "wrangler pages dev",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json",
    "migrate:local": "wrangler d1 migrations apply ipua-logs --local",
    "migrate:remote": "wrangler d1 migrations apply ipua-logs --remote",
    "seed": "node tools/seed-local.mjs",
    "apidoc": "node tools/build-apidoc.mjs",
    "checks": "npm run typecheck && npm run test",
    "deploy": "npm run apidoc && wrangler pages deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.12",
    "@cloudflare/workers-types": "^4.20251011.0",
    "typescript": "^5.5.0",
    "vitest": "~3.2.0",
    "wrangler": "~4.44.0"
  }
}
